# LLM: GEMINI_API_KEY와 OPENAI_API_KEY 중 채워진 쪽을 씁니다. 둘 다 있으면 기본은 Gemini (LLM_PROVIDER=auto).
# 강제: LLM_PROVIDER=gemini | openai | auto
LLM_PROVIDER=auto
GEMINI_API_KEY=
# 비우면 gemini-1.5-flash (Google AI Studio / Vertex에서 쓰는 모델 ID로 변경 가능)
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
ANTHROPIC_API_KEY=
# 기술명세서용 인스트럭션 파일 (비우면 프로젝트 루트의 reference/instruction.md). 절대경로 또는 cwd 기준 상대경로.
INSTRUCTION_FILE=
GITHUB_TOKEN=
GIT_CLONE_TIMEOUT_MS=120000
LIBREOFFICE_TIMEOUT_MS=180000
SOFFICE_PATH=
GITHUB_ZIP_TIMEOUT_MS=120000
PORT=8787
SERVER_TIMEOUT_MS=600000
SERVE_STATIC=
