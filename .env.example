# LLM: GOOGLE_API_KEY(Vertex express)와 OPENAI_API_KEY 중 채워진 쪽을 씁니다. 둘 다 있으면 기본은 Gemini (LLM_PROVIDER=auto).
# 강제: LLM_PROVIDER=gemini | openai | openrouter | auto
LLM_PROVIDER=auto
# Vertex AI express mode API key — https://cloud.google.com/vertex-ai/generative-ai/docs/start/api-keys
GOOGLE_API_KEY=
# 비우면 gemini-2.5-flash (Vertex express에서 사용 가능한 모델 ID로 변경 가능)
GEMINI_MODEL=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
# OpenRouter (LLM_PROVIDER=openrouter 일 때만 사용, base URL은 코드에 고정)
OPENROUTER_API_KEY=
# 비우면 openrouter/free — 무료 모델은 기술명세/슬라이드 JSON 단계에서 불안정할 수 있음
OPENROUTER_MODEL=
# OPENROUTER_HTTP_REFERER=http://localhost:8787
# OPENROUTER_APP_TITLE=git2ppt
# 기술명세서용 인스트럭션 파일 (비우면 프로젝트 루트의 reference/instruction.md). 절대경로 또는 cwd 기준 상대경로.
INSTRUCTION_FILE=
GITHUB_TOKEN=
GIT_CLONE_TIMEOUT_MS=120000
LIBREOFFICE_TIMEOUT_MS=180000
SOFFICE_PATH=
GITHUB_ZIP_TIMEOUT_MS=120000
PORT=8787
SERVER_TIMEOUT_MS=600000
SERVE_STATIC=
